#include <stdio.h>
#include <string.h>
#include <math.h>
#include <stdlib.h>
#include <stdbool.h>

int camada(int m, int n, int i, int j, int x, int y, int **mat){
    if(mat[i][j] > 0){ 
        if(x<m && y<n){
            if(i == x && j == y){ return 1; }
            else if(x+1<m && (i==x+1 && j == y)){ return 1; }
            else if(y+1<n && (i==x && j == y+1)){ return 1; }
            else if(x-1>=0 && (i == x-1 && j==y)){ return 1; }
            else if(y-1 >=0 && (i == x && j == y-1)){ return 1; }

            else if(x-2>=0 && (i == x-2 && j == y)){ return 2;}
            else if(x+2<m && (i == x+2 && j == y)){ return 2;}
            else if(y-2>=0 && (i == x && j == y-2)){ return 2;}
            else if(y+2<n && (i == x && j == y+2)){ return 2;}
            else if((x-1 >= 0 && y+1 < n) && (i == x-1 && j == y + 1)){ return 2;}
            else if((x-1 >= 0 && y-1 >= 0) && (i == x-1 && j == y - 1)){ return 2;}
            else if((x+1 < m && y-1 >= 0) && (i == x+1 && j == y - 1)){ return 2;}
            else if((x+1 < m && y+1 < n) && (i == x+1 && j == y + 1)){ return 2;}
            else if((x-2 >= 0 && y-1 >= 0) && (i == x-2 && j == y - 1)){ return 2;}
            else if((x-2 >= 0 && y+1 < n) && (i == x-2 && j == y + 1)){ return 2;}
            else if((x+2 < m && y-1 >= 0) && (i == x+2 && j == y - 1)){ return 2;}
            else if((x+2 < m && y+1 < n) && (i == x+2 && j == y + 1)){ return 2;}
            else if((x-1 >= 0 && y-2 >= 0) && (i == x-1 && j == y - 2)){ return 2;}
            else if((x+1 < m && y-2 >= 0) && (i == x+1 && j == y - 2)){ return 2;}
            else if((x-1 >= 0 && y+2 < n) && (i == x-1 && j == y + 2)){ return 2;}
            else if((x+1 < m && y+2 < n) && (i == x+1 && j == y + 2)){ return 2;}
        }
    }
    return 0;
}

int qtd_vizinhos(int m, int n, int i, int j, int **mat){
    int qtd = 0;
    if(i - 1>= 0 && mat[i-1][j] > 0){qtd++;}
    if(i + 1 < m && mat[i+1][j] > 0){qtd++;}
    if(j - 1>= 0 && mat[i][j-1] > 0){qtd++;}
    if(j + 1 < n && mat[i][j+1] > 0){qtd++;}
    if((i - 1>= 0 && j - 1>=0) && mat[i-1][j-1] > 0){qtd++;}
    if((i - 1>= 0 && j + 1<n) && mat[i-1][j+1] > 0){qtd++;}
    if((i + 1 < m && j - 1>=0) && mat[i+1][j-1] > 0){qtd++;}
    if((i + 1 < m && j + 1<n) && mat[i+1][j+1] > 0){qtd++;}
    return qtd;
}

int explosao(int m, int n, int i, int j, int x, int y, int **mat){
    int c = camada(m, n, i, j, x, y, mat);
    int hp = mat[i][j];

    if(c == 1){
        hp = hp - 50;
    }else if(c == 2){
        hp = hp - 25;
    }

    if(hp < 0){
        hp = 0;
    }

    return hp;
}

int veneno(int m, int n, int i, int j, int x, int y, int **mat){
    int c = camada(m, n, i, j, x, y, mat);
    int hp = mat[i][j];

    if(c == 1 || c == 2){
        int qtd = qtd_vizinhos(m, n, i, j, mat);
        hp = hp - (5 + (8 * qtd));
    }

    if(hp < 0){
        hp = 0;
    }

    return hp;
}

int** processar(int (*operacao)(int, int, int, int, int, int, int**), int **mat, int m, int n, int x, int y, int turnos){
    
    for(int t = 0; t < turnos; t++){
        int **nova_mat = (int**) malloc(m * sizeof(int*));
        bool ainda_tem_vivos = false;

        for(int i = 0; i<m; i++){
            nova_mat[i] = (int*) malloc(n * sizeof(int));
            for(int j = 0; j<n; j++){
                nova_mat[i][j] = operacao(m, n, i, j, x, y, mat);
                
                if(nova_mat[i][j] > 0 && camada(m, n, i, j, x, y, mat) > 0){
                    ainda_tem_vivos = true;
                }
            }
        }

        for(int i = 0; i<m; i++){
            free(mat[i]);
        }
        free(mat);
        mat = nova_mat;

        for(int i = 0; i<m; i++){
            for(int j = 0; j<n; j++){
                printf("%d ", mat[i][j]);
            }
            printf("\n");
        }

        if(ainda_tem_vivos == false){
            break;
        }

        if(t < turnos - 1){
            printf("\n");
        }
    }
    
    return mat;
}

int main(){ 
    int m, n; 
    if(scanf("%d %d", &m, &n) != 2) return 1;

    int **mat = (int**) malloc(m * sizeof(int*));
    for(int i = 0; i<m; i++){
        mat[i] = (int*) malloc(n * sizeof(int));
    }

    for(int i = 0; i<m; i++){
        for(int j = 0; j<n; j++){
            scanf("%d", &mat[i][j]);
        }
    }

    int x, y;
    scanf("%d %d", &x, &y);

    char escolha[100];
    scanf("%s", escolha);

    printf("Estado inicial do mapa:\n");
    for(int i = 0; i<m; i++){
        for(int j = 0; j<n; j++){
            printf("%d ", mat[i][j]);
        }
        printf("\n");
    }

    int (*ptr)(int, int, int, int, int, int, int**);

    if(strcmp(escolha, "EXPLOSAO_ARCANA") == 0){
        printf("\nEstado do mapa após usar a Explosão Arcana:\n");
        ptr = explosao;
        mat = processar(ptr, mat, m, n, x, y, 1);
    }else if(strcmp(escolha,"NUVEM_VENENOSA") == 0){
        printf("\nEstado do mapa, por turno, após usar a Nuvem Venenosa:\n");
        ptr = veneno;
        mat = processar(ptr, mat, m, n, x, y, 3);
    }

    for(int i = 0; i<m; i++){
        free(mat[i]);
    }
    free(mat);

    return 0;
}
